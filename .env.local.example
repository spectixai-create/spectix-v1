# =====================================================================
# Spectix POC — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local.
# =====================================================================

# ---- Supabase (Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Inngest ----
# In local dev with `npx inngest-cli dev` you can leave these blank and set INNGEST_DEV=1.
# In production (Vercel) both must be set from the Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# INNGEST_DEV=1

# =====================================================================
# Deferred to later spikes — DO NOT REMOVE, just leave commented.
# =====================================================================
# EXCHANGERATE_API_KEY=
# GOOGLE_PLACES_API_KEY=
# IPDATA_API_KEY=
# AZURE_DOCINTEL_ENDPOINT=
# AZURE_DOCINTEL_KEY=
