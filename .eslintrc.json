{
  "extends": ["next/core-web-vitals", "plugin:tailwindcss/recommended"],
  "settings": {
    "tailwindcss": {
      "callees": ["cn"],
      "whitelist": ["toaster", "toast"]
    }
  },
  "rules": {
    "tailwindcss/enforces-shorthand": "off",
    "tailwindcss/no-unnecessary-arbitrary-value": "off",
    "tailwindcss/no-custom-classname": "warn"
  }
}
